# --- App ---
NODE_ENV=development
PORT=3000
API_PREFIX=v1

# --- AI provider selection (provider-agnostic layer) ---
# kb (verified knowledge base, default) | openai | anthropic | gemini
LLM_PROVIDER=kb
VISION_PROVIDER=mock

# Provider credentials (leave empty to use the knowledge base)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Database (next step; not required for Sprint 1 mock run) ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cargpt

# --- Security ---
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
