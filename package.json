{
  "name": "cargpt",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspace packages/shared && npm run build --workspace apps/api",
    "test": "npm test --workspace apps/api",
    "start:dev": "npm run start:dev --workspace apps/api"
  },
  "engines": {
    "node": ">=20"
  }
}
